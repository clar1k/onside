{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "ts-node": { "transpileOnly": true },
  "include": ["src/**/*.ts"]
}
