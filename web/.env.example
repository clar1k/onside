# Copy to .env.local and fill in.  NEVER commit .env.local — it is git-ignored.

# ── Required ────────────────────────────────────────────────────────────────
# Solana devnet RPC URL. The public endpoint works but rate-limits under load;
# a keyed Helius / OnFinality devnet URL removes the throttling for a demo.
NEXT_PUBLIC_RPC=https://api.devnet.solana.com

# ── Optional (client-visible) ───────────────────────────────────────────────
# Fallback match-video URL for the live "Watch live" player.
# NEXT_PUBLIC_DEMO_STREAM_URL=https://www.youtube.com/watch?v=-z4BJeCLTIs

# ── Optional (server-only secrets) ──────────────────────────────────────────
# Faucet treasury private key as a JSON byte array. If unset, the /api/fund
# route falls back to ~/.config/solana/id.json for local development.
# TREASURY_SECRET_KEY=[12,34,56,...]

# TxODDS Tx LINE credentials. If unset, the app reads client/.txline-token.json
# (generated by `cd client && npx tsx src/get-token.ts`).
# TXLINE_JWT=
# TXLINE_API_TOKEN=
