@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  color-scheme: dark;
}

html,
body {
  background-color: #12161a;
}

body {
  @apply text-ink antialiased;
}

/* Thin, unobtrusive scrollbars */
* {
  scrollbar-width: thin;
  scrollbar-color: #252c34 transparent;
}
*::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}
*::-webkit-scrollbar-thumb {
  background: #252c34;
  border-radius: 9999px;
}
