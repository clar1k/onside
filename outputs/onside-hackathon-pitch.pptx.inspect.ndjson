{"kind":"textbox","id":"sh/rmxw7atg","slide":1,"text":"Football markets settled by proof,\nnot opinion.","textPreview":"Football markets settled by proof, | not opinion.","textChars":47,"textLines":2,"bbox":[72,288,880,142]}
